const site = siteFromHost();
const a = appBySlug('postscript')!;
const b = appBySlug('brevo')!;
const path = '/compare/postscript-vs-brevo';
const title = 'Postscript vs Brevo for Shopify Marketing Stack';
const desc = 'Stack battlecard: Postscript vs Brevo — lifecycle fit, capture, SMS, reviews, loyalty, pricing, and team reality for Shopify marketing apps in 2026.';

const faqs = [
  { question: 'Which fits a Shopify marketing stack better — Postscript or Brevo?', answer: 'Depends on stack role. Postscript fits sms marketing; Brevo fits email, sms & transactional. Evaluate Sequenzy as lifecycle layer when neither should own the full command center.' },
  { question: 'Can I run Postscript and Brevo together?', answer: 'Only with explicit ownership and suppressions. Overlapping lifecycle tools without a collision calendar trains unsubscribes.' },
  { question: 'Where does Sequenzy fit?', answer: 'Lifecycle and automation layer for welcome through winback — coordinating capture, SMS, and proof handoffs.' },
