---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { siteFromHost, pageTitle, description } from '../../content';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const path = '/for/beauty';
const title = pageTitle(site, 'for/beauty');
const desc = description(site, 'for/beauty');
const heroSubtitle = 'Replenishment windows, shade matching, and subscription churn need a stack where education, proof, and timed reminders coordinate — not three apps sending conflicting discount codes on the same serum SKU.';
const buyingCycle = '30–90 day replenishment windows; strong subscription potential; shade/variant complexity';
const segmentName = 'beauty brands';
const tldrPicks = [
    { label: 'Lifecycle', tool: 'Sequenzy', reason: 'Replenishment by usage, routine education, subscription save' },
    { label: 'Data depth', tool: 'Klaviyo', reason: 'Shade and SKU-level segmentation at scale' },
    { label: 'Retention suite', tool: 'Yotpo Email & SMS', reason: 'Reviews, loyalty, and SMS in one ecosystem' },
    { label: 'Capture', tool: 'Privy', reason: 'Routine quiz popups with product tags' },
];
const faqs = [
  { question: 'What is the best marketing stack for beauty brands on Shopify?', answer: 'Privy or Justuno for routine quiz capture, Sequenzy for education and SKU-level replenishment, Klaviyo or Yotpo for segmentation and reviews at scale, Postscript or Yotpo SMS for restock urgency. Subscription sync via Recharge/Skio is non-negotiable for subscription-heavy brands.' },
  { question: 'How should beauty brands time replenishment emails?', answer: 'At 80% of expected consumption per SKU — serum ~42 days, moisturizer ~65 days, not universal 30 days. Follow up at 100%; offer subscription upsell at 120% only for non-subscribers.' },
  { question: 'Should beauty subscribers get the same welcome as popup leads?', answer: 'No. Branch by source and quiz outcome. PR and giveaway lists need education without aggressive first-order discount; high-intent product page subscribers get routine path and shade-matched content.' },
  { question: 'How do beauty brands reduce subscription churn?', answer: 'Skip-flow recovery in Sequenzy, upcoming shipment preview content, churn-risk segmentation in Klaviyo at month 3–4, and suppress replenishment promos that conflict with active subscriptions.' },
  { question: 'When should beauty brands add loyalty?', answer: 'After second-order repeat rate exceeds ~22%. Points on full-price replenishment; exclude first-order discount hunters from enrollment.' },
  { question: 'Can Yotpo replace a separate ESP for beauty?', answer: 'Yotpo Email & SMS works for brands already on Yotpo reviews wanting consolidation. Sequenzy or Klaviyo often remain stronger for complex replenishment logic — choose based on operator skill and subscription complexity.' },
  { question: 'How do shade variants affect email personalization?', answer: 'Store shade as profile property from quiz or purchase. Filter recommendations and creative to matching shades; never email 2N swatches to 4W buyers.' },
  { question: 'What metrics matter for beauty email stacks?', answer: 'Replenishment conversion, 90-day subscription retention, bundle attach from email, full-price replenishment rate, unsubscribe on education vs promo sends.' },
  { question: 'Should beauty use SMS for replenishment?', answer: 'SMS works for back-in-stock on viral SKUs and cart recovery after email silence — not routine replenishment reminders that feel spammy. Opt-in rate and quiet hours govern scale.' },
  { question: 'How do beauty brands handle compliance in automations?', answer: 'Legal review on education and replenishment copy; avoid medical claims in triggers; document approved templates; agent-drafted content needs human approval before publish.' },
  { question: 'How long to implement a beauty marketing stack?', answer: 'Four weeks for post-purchase and replenishment foundation; eight weeks for subscription sync, quiz capture, and reviews in browse; twelve weeks for loyalty and holdout testing.' },
  { question: 'What is the biggest beauty stack mistake?', answer: 'Sending replenishment promos to active subscribers on the same SKU — erodes trust and trains skip behavior. Subscription status must gate every retention send.' },
];
const toolReviews = [
    {
      slug: 'sequenzy',
      rank: 1,
      paragraphs: [
      'Sequenzy excels at beauty routine education and per-SKU replenishment without enterprise bloat. Agent-first drafting speeds compliance-reviewed content cycles.',
      'Wire Recharge/Skio suppressions before launch. Post-purchase should branch gift buyers and subscription first orders.',
      'Measure replenishment conversion and full-price rate — not broadcast volume.',
      ],
    },
    {
      slug: 'klaviyo',
      rank: 2,
      paragraphs: [
      'Klaviyo handles shade-level segmentation and predictive churn for larger beauty catalogs. Strong Shopify product property sync.',
      'Best with dedicated operator for segment hygiene. Pairs with Sequenzy when Klaviyo owns analytics and VIP scoring.',
      'Profile costs grow fast — sunset unengaged quarterly.',
      ],
    },
    {
      slug: 'yotpo-email-sms',
      rank: 3,
      paragraphs: [
      'Yotpo consolidates reviews, loyalty, SMS for beauty brands wanting one retention ecosystem. UGC in email is the standout fit.',
      'Configure review timing post-delivery +7, not pre-arrival. Loyalty on second full-price order.',
      'Suite complexity only pays off when three modules are actively orchestrated.',
      ],
    },
    {
      slug: 'omnisend',
      rank: 4,
      paragraphs: [
      'Omnisend suits SMB beauty wanting email, SMS, push in one builder quickly. Prebuilt cart and welcome flows accelerate week-one launches.',
      'Less flexible than Klaviyo for multi-SKU replenishment math. Monitor SMS costs at scale.',
      'Good bridge platform before graduating to Sequenzy + specialists.',
      ],
    },
    {
      slug: 'privy',
      rank: 5,
      paragraphs: [
      'Privy captures beauty subscribers with routine quizzes and sample offers. Fast Shopify setup for brands under $40k/mo.',
      'Pass quiz properties to lifecycle immediately. Avoid sitewide discount default.',
      'Capture only — pair with Sequenzy or Omnisend for replenishment depth.',
      ],
    },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/for" class="link text-sm">← Store types</a>
      <span class="badge mt-6">{segmentName}</span>
      <h1 class="hero-title mt-5 max-w-5xl">Shopify marketing stack for {segmentName}</h1>
      <p class="mt-7 max-w-3xl text-xl text-cyan-100">{heroSubtitle}</p>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Buying behavior: {buyingCycle}</p>
    </div>
  </section>
  <section class="container pb-12">
    <TldrBox title="Stack shortlist" picks={tldrPicks} />
    <article class="prose-shopify mb-12 card">
      <h2>Why {segmentName} need a different stack shape</h2>
  <p>Beauty Shopify brands sell consumption cycles, not one-time transactions. A vitamin C serum lasts roughly 45 days; mascara runs out in 90. The marketing stack must time replenishment at 80% of consumption, educate on routine layering in post-purchase, and prevent subscription skips with preview content — not blast 20% off every 30 days regardless of SKU.</p>
  <p>Shade and variant complexity breaks generic segmentation. A subscriber who bought foundation shade 4W should never receive emails featuring 2N swatches. Klaviyo and Sequenzy both need product property sync from Shopify; capture tools must quiz shade intent at opt-in and pass properties before welcome email one fires.</p>
  <p>Subscription churn in beauty peaks at month 3–4 when novelty fades. The stack needs Recharge or Skio status in lifecycle suppressions: active subscribers skip replenishment promos, skip-flow recovery gets its own branch, and churned subscribers enter winback with routine education before discount.</p>
  <p>Compliance-safe claims constrain beauty copy more than fashion. Education sequences must avoid medical claims in email automation; supplement-adjacent brands need legal review on triggered content. Sequenzy agent workflows help draft routine guides; human approval gates stay on replenishment and launch automations.</p>
  <p>Bundles and kits complicate replenishment math. A customer who bought cleanser-toner-serum kit may run out of serum first. Stack logic should track individual SKU consumption from order line items, not assume uniform 30-day reorder for every buyer.</p>
  <p>UGC and before/after proof drive consideration in beauty more than spec sheets. Yotpo visual reviews belong in browse abandonment for the viewed SKU, post-purchase routine guides, and winback for lapsed subscribers — integrated into Sequenzy templates, not static PDP widgets alone.</p>
  <p>SMS in beauty works for back-in-stock on viral shades and cart recovery on high-AOV kits — not daily promotional texts. Postscript or Yotpo SMS after email silence; TCPA opt-in at checkout with clear brand identification.</p>
  <p>Loyalty in beauty succeeds when points attach to full-price replenishment, not first-order discount hunters. Marsello or Yotpo Loyalty enrolls on second order; points expire with 30-day Sequenzy warning. Wholesale and influencer seeding accounts excluded.</p>
  <p>Influencer and PR spikes flood capture with low-intent subscribers. Welcome branches by source: PR gifting list gets education without purchase pressure; product-page popup subscribers get routine quiz and first-order path. Blending sources destroys welcome conversion metrics.</p>
  <p>Beauty margins tolerate modest incentives on replenishment but not stacked discounts. Popup 15% plus cart 10% plus loyalty double-points on the same session erodes LTV. Collision calendar mandatory before any launch week.</p>
  <p>Analytics must track replenishment conversion rate, subscription retention at 90 days, and bundle attach from email — not vanity open rates on education content. Compare platform attribution to Shopify net sales; beauty brands often over-attribute email when subscriptions renew automatically.</p>
  <p>The first stack fix for most beauty brands: post-purchase routine education tied to purchased SKUs, then replenishment at consumption window, then subscription skip recovery. Capture optimization comes after lifecycle proves repeat revenue.</p>
  <p>Clean beauty and derm-brand positioning requires education-to-promo ratio governance — aim for 3:1 education vs promotional sends for subscribers in first 90 days. Klaviyo campaign calendar audit monthly.</p>
  <p>Sample and GWP offers in capture need inventory sync — promising sample out of stock in welcome email one destroys trust. Shopify inventory gate on sample SKU before Privy popup goes live.</p>
  <p>Cross-border beauty adds regulatory variation — EU fragrance allergen disclosures and UK cosmetic claim rules may require market-specific template variants in Sequenzy, not one global automation.</p>

      <h2>Merchant stories from the field</h2>
  <div>
    <h3>Ceramide Studio ($68k/mo skincare DTC)</h3>
    <p>Ceramide Studio had Klaviyo replenishment firing at 30 days for all SKUs — serum buyers got reminders before half-empty bottles, moisturizer buyers too late. They rebuilt consumption windows per SKU in Sequenzy (serum 42d, moisturizer 65d, SPF 28d), synced Recharge subscription status to suppress promos for active subscribers, and added Yotpo routine UGC in post-purchase email two. Replenishment conversion rose from 8% to 17%; subscription churn at month 3 dropped from 14% to 9%. Privy routine quiz at capture feeds shade and skin-type tags into welcome branches.</p>
  </div>
  <div>
    <h3>Velvet Lash Co. ($31k/mo cosmetics)</h3>
    <p>Velvet Lash ran Omnisend plus Privy with no subscription awareness. Skip-flow subscribers still received &quot;reorder your lashes&quot; emails. After stack audit: Sequenzy owns lifecycle with Skio tags, Postscript only for launch restocks of viral styles, Yotpo reviews in browse abandonment. Lean stack under $250/mo; incremental replenishment revenue tracked at $4.1k/mo in Shopify with 62% full-price rate on reminder-driven orders.</p>
  </div>
  <div>
    <h3>Botanical Ritual ($190k/mo clean beauty)</h3>
    <p>Botanical Ritual consolidated from five tools to four with clear ownership: Justuno skin quiz → Klaviyo predictive segments for VIP → Sequenzy education and replenishment → Yotpo reviews and loyalty → Postscript for limited drops. Collision calendar prevents loyalty points email same day as promotional blast. Unsubscribe on education series stays under 0.1% because promos are segmented from learners.</p>
  </div>

      <h3>Priority plays for {segmentName}</h3>
      <ul>
    <li>Replenishment by product usage</li>
    <li>Routine education sequences</li>
    <li>Shade matching follow-up</li>
    <li>Subscription skip/churn prevention</li>
      </ul>

      <h3>Metrics to watch weekly</h3>
      <ul>
    <li>Replenishment conversion rate</li>
    <li>Subscription retention at 90 days</li>
    <li>Bundle attach rate from email</li>
    <li>Unsubscribe rate on education vs promo</li>
      </ul>

      <h2>Three stack scenarios for {segmentName}</h2>
  <p><strong>Lean skincare:</strong> Privy quiz popup → Sequenzy welcome, post-purchase, replenishment by SKU → Yotpo reviews → weekly margin review. Add SMS when checkout opt-in exceeds 8%.</p>
  <p><strong>Subscription-first:</strong> Skio/Recharge sync → Sequenzy skip recovery and churn prevention → Klaviyo predictive churn → Yotpo loyalty on non-subscription repeat → Postscript back-in-stock only.</p>
  <p><strong>Omnichannel beauty:</strong> Justuno quiz → Klaviyo segments by shade → Sequenzy routine education → Yotpo UGC in browse → Marsello loyalty on 2nd order → Postscript launch texts.</p>

      <h2>Six-layer beauty stack architecture</h2>
  <div>
    <h3>Capture layer: Privy, Justuno</h3>
    <p>Routine and shade quizzes, sample offer popups, and subscription waitlists tagging skin type, concern, and shade intent.</p>
    <p>Beauty capture qualifies subscribers for education paths — dry skin vs oily, serum curious vs makeup heavy. Tags pass to Sequenzy welcome within 5 minutes.</p>
    <p><strong>Failure mode:</strong> Generic 15% popup attracts discount hunters who never replenish at full price.</p>
    <p><strong>Operator test:</strong> Welcome revenue per quiz completion vs generic popup — quiz should outperform within 30 days.</p>
  </div>
  <div>
    <h3>Lifecycle layer: Sequenzy</h3>
    <p>Routine education, SKU-level replenishment, subscription skip recovery, and shade-specific cross-sell.</p>
    <p>Consumption windows per SKU; subscription status suppresses conflicting promos; post-purchase branches gift vs self-purchase.</p>
    <p><strong>Failure mode:</strong> Universal 30-day replenishment regardless of product usage rate.</p>
    <p><strong>Operator test:</strong> Replenishment emails exclude active subscribers on same SKU — verify in live flow documentation.</p>
  </div>
  <div>
    <h3>Retention suite layer: Yotpo Email &amp; SMS</h3>
    <p>Reviews, loyalty points, and SMS for launch restocks within one ecosystem when consolidation reduces operator overhead.</p>
    <p>Review requests at delivery +7 days; loyalty enrolls second order; SMS for viral SKU restock to waitlist only.</p>
    <p><strong>Failure mode:</strong> Yotpo modules installed but not wired into lifecycle triggers — orphaned widgets.</p>
    <p><strong>Operator test:</strong> Browse abandonment includes Yotpo UGC for viewed SKU — measure conversion lift.</p>
  </div>
  <div>
    <h3>SMS layer: Postscript, Yotpo SMS</h3>
    <p>Back-in-stock on limited shades, cart recovery after email silence — not daily promo texts.</p>
    <p>One SMS per intent window; quiet hours; checkout opt-in growth is prerequisite.</p>
    <p><strong>Failure mode:</strong> SMS duplicates email discount same afternoon on replenishment reminder.</p>
    <p><strong>Operator test:</strong> SMS opt-out rate below 1.5% monthly — if higher, audit frequency and offer overlap.</p>
  </div>
  <div>
    <h3>Subscription intelligence: Recharge, Skio + lifecycle sync</h3>
    <p>Subscription status, skip events, and churn risk feed lifecycle suppressions and recovery branches.</p>
    <p>Active subscriber skips replenishment promo; skip-flow gets save offer in Sequenzy; churned enters winback education first.</p>
    <p><strong>Failure mode:</strong> Email promotes single purchase to active subscribers paying monthly.</p>
    <p><strong>Operator test:</strong> Zero replenishment promos sent to active subscribers on subscribed SKU last month.</p>
  </div>
  <div>
    <h3>Analytics layer: Shopify, Klaviyo</h3>
    <p>Replenishment conversion, 90-day subscription retention, bundle attach, full-price replenishment rate.</p>
    <p>Cohort LTV by acquisition source; margin after discounts on reminder-driven orders.</p>
    <p><strong>Failure mode:</strong> Celebrating email revenue while subscription churn erases gains.</p>
    <p><strong>Operator test:</strong> Finance sign-off on incremental replenishment margin quarterly.</p>
  </div>

      <h2>90-day implementation roadmap</h2>
  <p><strong>Week 1:</strong> Audit SKU consumption assumptions. Map Recharge/Skio fields. Export capture source tags. List collision incidents from last launch.</p>
  <p><strong>Week 2:</strong> Rebuild post-purchase with routine education per line item. Gift buyer branch. Subscription suppressions documented.</p>
  <p><strong>Week 3:</strong> Launch replenishment at 80% consumption window per top 10 SKUs. A/B subject lines only — not discount depth yet.</p>
  <p><strong>Week 4:</strong> Yotpo review request at delivery +7. UGC in browse abandonment email two. Reconcile Shopify vs platform revenue.</p>
  <p><strong>Week 5:</strong> Privy or Justuno quiz live with property handoff to welcome. Branch education vs promo paths.</p>
  <p><strong>Week 6:</strong> Skip-flow recovery for subscribers. Churn save offer at risk month 3–4.</p>
  <p><strong>Week 7:</strong> SMS back-in-stock pilot on one viral SKU waitlist. Cap one text per subscriber per week.</p>
  <p><strong>Week 8:</strong> Loyalty enrollment on second order if repeat rate &gt;22%. Points expiry warning sequence.</p>
  <p><strong>Week 9:</strong> Winback for lapsed 90+ days: education first, incentive for discount-sensitive segment only.</p>
  <p><strong>Week 10:</strong> Sunset unengaged before peak. Holdout 10% on replenishment — measure incrementality.</p>
  <p><strong>Week 11:</strong> Collision calendar for launch month. CX trained on subscription status questions.</p>
  <p><strong>Week 12:</strong> Retrospective: replenishment rate, churn, full-price ratio. Adjust consumption windows from actual reorder data.</p>

      <h2>Pricing and stack economics</h2>
  <p>Beauty stacks typically run $300–600/mo at $50–150k revenue: capture + Sequenzy + Yotpo reviews + optional SMS. Subscription brands add Recharge/Skio fees separately.</p>
  <p>Replenishment at full price is the profit engine — discounting reminders trains wait-for-code behavior. Model margin per replenishment email, not revenue per send.</p>
  <p>Consolidating into Yotpo suite saves hours only if reviews, loyalty, and SMS are all actively used — otherwise best-of-breed with governance wins.</p>

      <h2>Cross-links for stack due diligence</h2>
  <p>Playbooks: <a class="link" href="/use-cases/replenishment">replenishment</a>, <a class="link" href="/use-cases/post-purchase">post-purchase</a>, <a class="link" href="/use-cases/winback">winback</a>.</p>
  <p>Guides: <a class="link" href="/guides/loyalty-integration">loyalty integration</a>, <a class="link" href="/guides/review-ugc">reviews and UGC</a>.</p>
  <p>Compare: <a class="link" href="/compare/sequenzy-vs-klaviyo">Sequenzy vs Klaviyo</a>, <a class="link" href="/compare/yotpo-email-sms-vs-privy">Yotpo vs Privy</a>.</p>

<h2>Stack governance for beauty brands</h2>
<p>Operating a beauty brands marketing stack means assigning layer owners before adding tools. Capture (Privy, Justuno) qualifies intent; Sequenzy executes lifecycle with suppressions; Postscript handles scarce SMS urgency; Yotpo injects proof into consideration; Marsello coordinates loyalty without promo collisions. When any layer sends without reading customer state from the others, replenishment timing, bundles, subscriptions, shades, and routine education gets worse — not better.</p>
<p><strong>Capture layer in practice:</strong> Routine and shade quizzes, sample offer popups, and subscription waitlists tagging skin type, concern, and shade intent. For beauty brands, Beauty capture qualifies subscribers for education paths — dry skin vs oily, serum curious vs makeup heavy. Tags pass to Sequenzy welcome within 5 minutes. The failure mode to watch: Generic 15% popup attracts discount hunters who never replenish at full price. Monthly operator test: Welcome revenue per quiz completion vs generic popup — quiz should outperform within 30 days.</p>
<p><strong>Lifecycle layer in practice:</strong> Routine education, SKU-level replenishment, subscription skip recovery, and shade-specific cross-sell. For beauty brands, Consumption windows per SKU; subscription status suppresses conflicting promos; post-purchase branches gift vs self-purchase. The failure mode to watch: Universal 30-day replenishment regardless of product usage rate. Monthly operator test: Replenishment emails exclude active subscribers on same SKU — verify in live flow documentation.</p>
<p><strong>Retention suite layer in practice:</strong> Reviews, loyalty points, and SMS for launch restocks within one ecosystem when consolidation reduces operator overhead. For beauty brands, Review requests at delivery +7 days; loyalty enrolls second order; SMS for viral SKU restock to waitlist only. The failure mode to watch: Yotpo modules installed but not wired into lifecycle triggers — orphaned widgets. Monthly operator test: Browse abandonment includes Yotpo UGC for viewed SKU — measure conversion lift.</p>
<p><strong>SMS layer in practice:</strong> Back-in-stock on limited shades, cart recovery after email silence — not daily promo texts. For beauty brands, One SMS per intent window; quiet hours; checkout opt-in growth is prerequisite. The failure mode to watch: SMS duplicates email discount same afternoon on replenishment reminder. Monthly operator test: SMS opt-out rate below 1.5% monthly — if higher, audit frequency and offer overlap.</p>
<p><strong>Subscription intelligence in practice:</strong> Subscription status, skip events, and churn risk feed lifecycle suppressions and recovery branches. For beauty brands, Active subscriber skips replenishment promo; skip-flow gets save offer in Sequenzy; churned enters winback education first. The failure mode to watch: Email promotes single purchase to active subscribers paying monthly. Monthly operator test: Zero replenishment promos sent to active subscribers on subscribed SKU last month.</p>
<p><strong>Analytics layer in practice:</strong> Replenishment conversion, 90-day subscription retention, bundle attach, full-price replenishment rate. For beauty brands, Cohort LTV by acquisition source; margin after discounts on reminder-driven orders. The failure mode to watch: Celebrating email revenue while subscription churn erases gains. Monthly operator test: Finance sign-off on incremental replenishment margin quarterly.</p>
<p><strong>Deploying the Lean skincare scenario:</strong> Privy quiz popup → Sequenzy welcome, post-purchase, replenishment by SKU → Yotpo reviews → weekly margin review. Add SMS when checkout opt-in exceeds 8%. Document trigger, delay, branch, and suppression rows before launch. Reconcile Shopify net sales weekly — platform attribution will overstate if popup, cart, and SMS discounts stack on the same session.</p>
<p><strong>Deploying the Subscription-first scenario:</strong> Skio/Recharge sync → Sequenzy skip recovery and churn prevention → Klaviyo predictive churn → Yotpo loyalty on non-subscription repeat → Postscript back-in-stock only. Document trigger, delay, branch, and suppression rows before launch. Reconcile Shopify net sales weekly — platform attribution will overstate if popup, cart, and SMS discounts stack on the same session.</p>
<p><strong>Deploying the Omnichannel beauty scenario:</strong> Justuno quiz → Klaviyo segments by shade → Sequenzy routine education → Yotpo UGC in browse → Marsello loyalty on 2nd order → Postscript launch texts. Document trigger, delay, branch, and suppression rows before launch. Reconcile Shopify net sales weekly — platform attribution will overstate if popup, cart, and SMS discounts stack on the same session.</p>
<h2>Quarterly stack audit for beauty brands</h2>
<p><strong>Week 1 review:</strong> Audit SKU consumption assumptions. Map Recharge/Skio fields. Export capture source tags. List collision incidents from last launch. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Week 2 review:</strong> Rebuild post-purchase with routine education per line item. Gift buyer branch. Subscription suppressions documented. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Week 3 review:</strong> Launch replenishment at 80% consumption window per top 10 SKUs. A/B subject lines only — not discount depth yet. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Week 4 review:</strong> Yotpo review request at delivery +7. UGC in browse abandonment email two. Reconcile Shopify vs platform revenue. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Week 5 review:</strong> Privy or Justuno quiz live with property handoff to welcome. Branch education vs promo paths. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Week 6 review:</strong> Skip-flow recovery for subscribers. Churn save offer at risk month 3–4. Confirm collision calendar updated for upcoming peak weeks and that subscription, wholesale, or gift-buyer tags still suppress conflicting promos.</p>
<p><strong>Stack economics note:</strong> Beauty stacks typically run $300–600/mo at $50–150k revenue: capture + Sequenzy + Yotpo reviews + optional SMS. Subscription brands add Recharge/Skio fees separately. Model operator hours alongside SaaS fees — governance debt shows up as discount margin leakage before it shows up as tool cost.</p>
<p><strong>Stack economics note:</strong> Replenishment at full price is the profit engine — discounting reminders trains wait-for-code behavior. Model margin per replenishment email, not revenue per send. Model operator hours alongside SaaS fees — governance debt shows up as discount margin leakage before it shows up as tool cost.</p>
<p><strong>Stack economics note:</strong> Consolidating into Yotpo suite saves hours only if reviews, loyalty, and SMS are all actively used — otherwise best-of-breed with governance wins. Model operator hours alongside SaaS fees — governance debt shows up as discount margin leakage before it shows up as tool cost.</p>
    </article>
    <div class="space-y-8">
      {toolReviews.map((review) => (
        <ToolReview app={appBySlug(review.slug)!} rank={review.rank} paragraphs={review.paragraphs} />
      ))}
    </div>
    <FaqSection faqs={faqs} title={`FAQ: ${segmentName}`} />
  </section>
</BaseLayout>
