    { label: 'SMS reminder', tool: 'Postscript', reason: 'Reorder window SMS after email silence' },
];
const faqs = [
  { question: 'Best stack for replenishment?', answer: 'Sequenzy per-SKU timing, Klaviyo + Recharge suppressions, Privy consumption quiz data, Postscript SMS optional, Yotpo proof in email one.' },
  { question: 'Universal 30-day reminder?', answer: 'No — per-SKU consumption windows. Universal timer is the top replenishment failure.' },
