const site = siteFromHost();
const path = '/use-cases/replenishment';
const title = pageTitle(site, 'use-cases/replenishment');
const desc = description(site, 'use-cases/replenishment');
const heroSubtitle = 'Replenishment is the stack\'s consumption clock — Sequenzy per-SKU timing, Recharge subscription suppressions, Privy quiz properties, Postscript reorder SMS, and Klaviyo cohort reporting, not a universal 30-day timer that spams serum buyers before half-empty bottles.';
const useCaseName = 'replenishment reminders';
const trigger = 'Days since last purchase of consumable SKU exceeds usage window';
const timing = 'Reminder at 80% of expected consumption; follow-up at 100%; subscription upsell at 120%';
const tldrPicks = [
    { label: 'Lifecycle', tool: 'Sequenzy', reason: 'Per-SKU consumption windows at 80% depletion' },
