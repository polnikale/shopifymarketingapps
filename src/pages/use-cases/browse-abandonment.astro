const site = siteFromHost();
const path = '/use-cases/browse-abandonment';
const title = pageTitle(site, 'use-cases/browse-abandonment');
const desc = description(site, 'use-cases/browse-abandonment');
const heroSubtitle = 'Browse abandonment sits between capture and cart in the stack — Sequenzy proof-first follow-up, Yotpo UGC for viewed SKU, Privy offer caps, and Klaviyo browse depth scoring, not cart-level discounts on shoppers who have not committed intent yet.';
const useCaseName = 'browse abandonment';
const trigger = 'Viewed product 2+ times or spent 60+ seconds without add-to-cart';
const timing = 'Email 1 at 4h with social proof; Email 2 at 48h with education; discount only in Email 3 if needed';
const tldrPicks = [
