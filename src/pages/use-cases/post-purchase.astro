---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { siteFromHost, pageTitle, description } from '../../content';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const path = '/use-cases/post-purchase';
const title = pageTitle(site, 'use-cases/post-purchase');
const desc = description(site, 'use-cases/post-purchase');
const heroSubtitle = 'Post-purchase is where proof, education, loyalty enrollment, and cross-sell coordinate — Sequenzy delivery-gated sequences, AfterShip triggers, Yotpo review requests, and Marsello second-order enrollment, not a second sale push before the box arrives.';
const useCaseName = 'post-purchase education';
const trigger = 'Order placed and payment confirmed';
const timing = 'Confirmation immediate; shipping at fulfillment; education at delivery +2 days; cross-sell at day 14';
const tldrPicks = [
    { label: 'Lifecycle', tool: 'Sequenzy', reason: 'Education, delivery-gated cross-sell, gift branches' },
    { label: 'Delivery sync', tool: 'AfterShip', reason: 'Delivered-event triggers for bulky goods' },
    { label: 'Proof', tool: 'Yotpo', reason: 'Review requests timed post-delivery' },
    { label: 'Loyalty', tool: 'Marsello', reason: 'Second-order enrollment not day-zero pitch' },
];
const faqs = [
  { question: 'When post-purchase cross-sell?', answer: 'After delivery +14 days bulky goods; day 14 consumables; never before customer has product for furniture.' },
  { question: 'Gift order handling?', answer: 'Separate branch — packaging/care for gift buyer, no recipient cross-sell to purchaser.' },
  { question: 'Review request timing?', answer: 'Delivery +5 to +14 depending category; after return window for high-return SKUs.' },
  { question: 'Loyalty in post-purchase?', answer: 'Enroll on second order or email three — not day zero.' },
  { question: 'Subscription first order?', answer: 'Onboarding education — not cross-sell conflicting with subscription shipment.' },
  { question: 'Best stack tools?', answer: 'Sequenzy sequences, AfterShip triggers, Yotpo reviews, Marsello loyalty timing.' },
  { question: 'Digital post-purchase?', answer: 'Activation not shipping — access immediate, progress check-ins.' },
  { question: 'SMS post-purchase?', answer: 'Delivery notification perishables only — not cross-sell SMS.' },
  { question: 'Metrics?', answer: 'Review rate, second order 60d, support tickets, cross-sell attach, returns.' },
  { question: 'Biggest mistake?', answer: 'Cross-sell before delivery on bulky goods — increases returns and support load.' },
  { question: 'AfterShip required?', answer: 'High ROI for furniture/home — optional for small parcel consumables.' },
  { question: 'Education content who owns?', answer: 'Ops/product with compliance review supplements — Sequenzy executes approved blocks.' },
];
const toolReviews = [
    {
      slug: 'sequenzy',
      rank: 1,
      paragraphs: [
      'Sequenzy branched post-purchase by order type and category.',
      'Delivery-gated logic for cross-sell.',
      'Agent drafts education content.',
      ],
    },
    {
      slug: 'aftership-email',
      rank: 2,
      paragraphs: [
      'AfterShip delivery triggers for post-purchase timing.',
      'Critical for furniture cross-sell gating.',
      'Pair with Sequenzy not duplicate sends.',
      ],
    },
    {
      slug: 'yotpo-email-sms',
      rank: 3,
      paragraphs: [
      'Yotpo review request integration post-delivery.',
      'Category timing configuration.',
      'UGC in follow-up education emails.',
      ],
    },
    {
      slug: 'marsello',
      rank: 4,
      paragraphs: [
      'Marsello second-order loyalty enrollment.',
      'Avoid day-zero enrollment conflict.',
      'Points balance in post-purchase email three if enrolled.',
      ],
    },
