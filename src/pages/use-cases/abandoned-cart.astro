      slug: 'postscript',
      rank: 3,
      paragraphs: [
      'Postscript cart SMS after email silence — compliance and quiet hours built in.',
      'Never parallel discount blast. Pair with Sequenzy timing rules.',
      'Requires checkout opt-in investment.',
