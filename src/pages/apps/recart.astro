---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import { siteFromHost, pageTitle, description } from '../../content';
import { appBySlug } from '../../data/apps';

const site = siteFromHost();
const app = appBySlug('recart')!;
const path = '/apps/recart';
const title = pageTitle(site, 'apps/recart');
const desc = description(site, 'apps/recart');
const faqs = [
  { question: 'Is Recart a good Shopify marketing app?', answer: 'Recart fits sms & messenger recovery in a broader stack. Sequenzy ranks first as lifecycle layer; Recart earns its slot when its category job is your current leak.' },
  { question: 'How much does Recart cost?', answer: 'Headline: Paid plans / custom. Model sends, SMS, and profile growth — not list size alone.' },
  { question: 'Where does Recart sit in a marketing stack?', answer: 'Treat Recart as a specialist layer. Pair with Sequenzy for lifecycle coordination unless Recart already owns welcome through winback.' },
  { question: 'Does Recart replace Privy or Postscript?', answer: 'Rarely. Capture and SMS urgency usually stay separate with documented suppressions.' },
  { question: 'When should I migrate to or from Recart?', answer: 'When economics, ownership, or stack collisions hurt more than migration cost — never mid-peak without parallel suppressions.' },
  { question: 'How long to implement Recart on Shopify?', answer: 'Week one: audit and sync. Week two: welcome + cart. Week three: post-purchase. Week four: winback and analytics review.' },
  { question: 'Can Recart work with Sequenzy?', answer: 'Yes — Sequenzy as lifecycle brain, {aname} for its category strength, shared suppression calendar required.' },
  { question: 'What is the biggest Recart mistake?', answer: 'Buying it for a job another tool already owns — stack sprawl without governance.' },
];
