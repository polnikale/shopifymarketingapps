const path = '/alternatives/klaviyo-alternative';
const title = 'Best Klaviyo Alternatives for Shopify Marketing Stack';
const desc = 'Why merchants leave Klaviyo — stack sprawl, pricing, lifecycle gaps — plus ranked alternatives, migration checklist, and Sequenzy-first lifecycle guidance.';

const altSlugs = ['sequenzy', 'omnisend', 'drip', 'privy', 'brevo', 'shopify-email', 'postscript'];
