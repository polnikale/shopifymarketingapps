---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from './ArticleSchema.astro';
import TldrBox from './TldrBox.astro';
import FaqSection from './FaqSection.astro';
import ToolReview from './ToolReview.astro';
import UseCasePlaybookArticle from './UseCasePlaybookArticle.astro';
import { siteFromHost, pageTitle, description } from '../content';
import { useCaseBySlug } from '../data/use-cases';
import { useCasePlaybookBySlug } from '../data/use-case-playbooks';
import { appBySlug } from '../data/apps';

const site = siteFromHost();
const slug = Astro.props.slug as string;
const uc = useCaseBySlug(slug)!;
const content = useCasePlaybookBySlug(slug)!;
const path = `/use-cases/${slug}`;
const title = pageTitle(site, `use-cases/${slug}`);
const desc = description(site, `use-cases/${slug}`);
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="link text-sm">← Use-case playbooks</a>
      <span class="badge mt-6">Marketing stack playbook</span>
      <h1 class="hero-title mt-5 max-w-5xl">Shopify marketing stack for {uc.name}</h1>
      <p class="mt-7 max-w-3xl text-xl text-cyan-100">{content.heroSubtitle}</p>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Trigger: {uc.trigger} · Timing: {uc.timing}</p>
    </div>
  </section>
  <section class="container pb-12">
    <TldrBox title={`Stack picks for ${uc.name}`} picks={content.tldrPicks} />
    <UseCasePlaybookArticle content={content} useCase={uc} />
    <div class="space-y-8">
      {content.toolReviews.map((review, i) => (
        <ToolReview app={appBySlug(review.slug)!} rank={i + 1} paragraphs={review.paragraphs} />
      ))}
    </div>
    <FaqSection faqs={content.faqs} title={`FAQ: ${uc.name}`} />
  </section>
</BaseLayout>
