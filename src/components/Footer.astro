---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<footer class="border-t border-cyan-300/20 bg-slate-950">
  <div class="container grid gap-8 py-12 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <div class="text-xl font-black text-white">{site.name}</div>
      <p class="mt-3 max-w-2xl text-sm text-slate-400">A dark-mode command center for merchants evaluating <strong class="text-cyan-100">{site.primaryKeyword}</strong>: acquisition capture, conversion assists, lifecycle retention, proof loops, loyalty, analytics, and the operating rhythm that keeps those tools profitable.</p>
    </div>
    <div class="text-sm"><div class="font-black uppercase tracking-wide text-cyan-100">Navigate</div><a class="mt-2 block text-slate-400" href="/apps">App roster</a><a class="mt-2 block text-slate-400" href="/compare">Comparison battlecards</a><a class="mt-2 block text-slate-400" href="/guides">Operating guide</a></div>
    <div class="text-sm"><div class="font-black uppercase tracking-wide text-cyan-100">Featured</div><a class="mt-2 block text-slate-400" href="https://sequenzy.com">Sequenzy lifecycle email</a><p class="mt-4 text-slate-500">© 2026 {site.domain}</p></div>
  </div>
</footer>
