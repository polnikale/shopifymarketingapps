---
import type { SegmentPageContent } from '../data/segment-pages';
import type { Segment } from '../data/segments';

export interface Props {
  content: SegmentPageContent;
  segment: Segment;
}

const { content, segment } = Astro.props;
---

<article class="prose-shopify mb-12 card">
  <h2>Why {segment.name} need a different stack shape</h2>
  {content.intro.map((p) => <p>{p}</p>)}

  <h2>Merchant stories from the field</h2>
  {content.merchantStories.map((s) => (
    <div>
      <h3>{s.name} ({s.revenue})</h3>
      <p>{s.story}</p>
    </div>
  ))}

  <h3>Priority plays for {segment.name}</h3>
  <ul>{segment.emailPriorities.map((p) => <li>{p}</li>)}</ul>

  <h3>Metrics to watch weekly</h3>
  <ul>{segment.metrics.map((m) => <li>{m}</li>)}</ul>

  <h2>Three stack scenarios for {segment.name}</h2>
  {content.stackScenarios.map((s) => (
    <p><strong>{s.name}:</strong> {s.description}</p>
  ))}

  <h2>{content.stackArchitectureTitle}</h2>
  {content.stackLayers.map((layer) => (
    <div>
      <h3>{layer.name}: {layer.tools}</h3>
      <p>{layer.role}</p>
      <p>{layer.verticalFit}</p>
      <p><strong>Failure mode:</strong> {layer.failureMode}</p>
      <p><strong>Operator test:</strong> {layer.operatorTest}</p>
    </div>
  ))}

  <h2>90-day implementation roadmap</h2>
  {content.roadmap.map((r) => (
    <p><strong>{r.week}:</strong> {r.tasks}</p>
  ))}

  <h2>Pricing and stack economics</h2>
  {content.economics.map((p) => <p>{p}</p>)}

  <h2>Cross-links for stack due diligence</h2>
  {content.crossLinks.map((p) => <p set:html={p} />)}
</article>
