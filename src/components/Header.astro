---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<header class="sticky top-0 z-50 border-b border-cyan-300/20 bg-slate-950/80 backdrop-blur-2xl">
  <div class="container flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-3 font-black text-white">
      <span class="grid h-10 w-10 place-items-center rounded-2xl bg-cyan-300 text-slate-950 shadow-lg shadow-cyan-300/30">M</span>
      <span class="hidden sm:inline">{site.name}</span>
    </a>
    <nav class="hidden items-center gap-6 text-xs font-black uppercase tracking-[.18em] text-slate-300 md:flex">
      <a href="/apps" class="hover:text-cyan-200">Apps</a>
      <a href="/compare" class="hover:text-cyan-200">Battlecards</a>
      <a href="/use-cases" class="hover:text-cyan-200">Plays</a>
      <a href="/for" class="hover:text-cyan-200">Segments</a>
    </nav>
    <a href="https://sequenzy.com" class="btn btn-primary">Build lifecycle</a>
  </div>
</header>
