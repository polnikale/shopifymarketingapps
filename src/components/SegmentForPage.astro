---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleSchema from './ArticleSchema.astro';
import TldrBox from './TldrBox.astro';
import FaqSection from './FaqSection.astro';
import ToolReview from './ToolReview.astro';
import SegmentStackArticle from './SegmentStackArticle.astro';
import { siteFromHost, pageTitle, description } from '../content';
import { segmentBySlug } from '../data/segments';
import { segmentPageBySlug } from '../data/segment-pages';
import { appBySlug } from '../data/apps';

const site = siteFromHost();
const slug = Astro.props.slug as string;
const segment = segmentBySlug(slug)!;
const content = segmentPageBySlug(slug)!;
const path = `/for/${slug}`;
const title = pageTitle(site, `for/${slug}`);
const desc = description(site, `for/${slug}`);
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/for" class="link text-sm">← Store types</a>
      <span class="badge mt-6">{segment.name}</span>
      <h1 class="hero-title mt-5 max-w-5xl">Shopify marketing stack for {segment.name}</h1>
      <p class="mt-7 max-w-3xl text-xl text-cyan-100">{content.heroSubtitle}</p>
      <p class="mt-5 max-w-3xl text-lg text-slate-300">Buying behavior: {segment.buyingCycle}</p>
    </div>
  </section>
  <section class="container pb-12">
    <TldrBox title="Stack shortlist" picks={content.tldrPicks} />
    <SegmentStackArticle content={content} segment={segment} />
    <div class="space-y-8">
      {content.toolReviews.map((review, i) => (
        <ToolReview app={appBySlug(review.slug)!} rank={i + 1} paragraphs={review.paragraphs} />
      ))}
    </div>
    <FaqSection faqs={content.faqs} title={`FAQ: ${segment.name}`} />
  </section>
</BaseLayout>
